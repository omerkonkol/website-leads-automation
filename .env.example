# ════════════════════════════════════════════════
#  .env.example — העתק לקובץ .env ומלא את הפרטים
#  הקובץ .env לא עולה ל-GitHub (מוגן ב-.gitignore)
# ════════════════════════════════════════════════

# SerpApi (אופציונלי — 100 חינם/חודש: serpapi.com)
SERPAPI_KEY=

# Gmail — App Password (myaccount.google.com/apppasswords)
EMAIL_SENDER=your@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# פרטים שלך
YOUR_NAME=השם שלך
YOUR_PHONE=05X-XXXXXXX
YOUR_WHATSAPP_URL=https://wa.me/972XXXXXXXXX
YOUR_BIO=ביוגרפיה קצרה שתופיע בהודעות

# תיק עבודות (הפרד בפסיקים)
PORTFOLIO_LINKS=https://site1.com,https://site2.com,https://site3.com

# Anthropic API (אופציונלי — ליצירת אתרי דמו מתקדמים)
ANTHROPIC_API_KEY=

# GitHub Pages (לפרסום אתרי דמו)
GITHUB_USERNAME=
GITHUB_REPO=website-leads-automation

# Supabase (אופציונלי — לעבודת צוות, הירשם: supabase.com)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJ...anon-key
SUPABASE_MGMT_TOKEN=sbp_...personal-access-token
SUPABASE_PROJECT_REF=xxxxxxxxxxxx

# Telegram (אופציונלי — התראות כשנמצאו לידים חמים)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# סיסמת מנהל לעדכון DB מהדשבורד
ADMIN_PASSWORD=your-secret-password-here

# Google Sheets — שיתוף לידים עם חבר (חינמי, ללא שרת)
# מדריך הגדרה: console.cloud.google.com → Sheets API → Service Account → הורד JSON
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms
GOOGLE_CREDENTIALS_FILE=google_credentials.json
# או כ-JSON שלם (לפריסה בענן):
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
